<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="root" styleClass="dialog-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           stylesheets="@/css/strategie-list.css"
           fx:controller="com.advisora.GUI.Strategie.AddStrategieDialogController">

    <!-- Dark transparent overlay (visible during loading) -->
    <StackPane fx:id="overlay" visible="false" managed="false" styleClass="dialog-overlay">
        <ProgressIndicator maxWidth="80" maxHeight="80"/>
    </StackPane>

    <!-- Dialog card -->
    <VBox styleClass="dialog-card" spacing="14" style="-fx-background-color: #ffffff; -fx-opacity: 1; -fx-background-insets: 0;">

        <HBox fx:id="dragHandle" alignment="CENTER_LEFT" spacing="10" styleClass="dialog-header">
            <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: 800;" text="%strategie.dialog.title.new" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#close" styleClass="btn-base btn-ghost" text="X" />
        </HBox>

        <VBox spacing="6">
            <Label text="%strategie.field.name" />
            <TextField fx:id="nomField" promptText="%strategie.prompt.name" />
        </VBox>

        <VBox spacing="6">
            <Label text="%strategie.field.project" />
            <ComboBox fx:id="projetCombo" promptText="%strategie.prompt.project" />
            <Label fx:id="projectLockLabel"
                   text="%strategie.project.locked"
                   visible="false" managed="false"
                   style="-fx-text-fill: #d9534f; -fx-font-size: 12px;"/>
        </VBox>

        <VBox spacing="6">
            <Label text="%strategie.field.type" />
            <ComboBox fx:id="typeCombo" promptText="%strategie.prompt.type" />
        </VBox>

        <VBox spacing="6">
            <Label text="%strategie.field.budget" />
            <TextField fx:id="budgetTotalField" promptText="%strategie.prompt.budget" />
        </VBox>

        <VBox spacing="6">
            <Label text="%strategie.field.gain" />
            <TextField fx:id="gainEstimeField" promptText="%strategie.prompt.gain" />
        </VBox>

        <VBox spacing="6">
            <Label text="%strategie.field.status" />
            <ComboBox fx:id="statutCombo" />
        </VBox>

        <Label text="%strategie.field.term" />

        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="terme" promptText="%strategie.prompt.term" HBox.hgrow="ALWAYS"/>
            <Label text="%strategie.unit.days" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="6">
            <Button onAction="#close" styleClass="btn-base btn-ghost" text="%common.cancel" />
            <Button fx:id="saveBtn" onAction="#save" styleClass="btn-base btn-primary" text="%common.add" />
        </HBox>

    </VBox>

</StackPane>





