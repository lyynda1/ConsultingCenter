<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import javafx.scene.image.ImageView?>
<VBox spacing="14" prefWidth="520"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Auth.ResetPasswordController"
      stylesheets="@/GUI/Auth/login.css"
      styleClass="app auth-wrap">

    <padding><Insets top="30" right="30" bottom="30" left="30"/></padding>

    <VBox spacing="12" styleClass="card auth-card">
        <Label text="Reset Password" styleClass="card-title"/>
        <Label text="Enter the code you received and choose a new password" styleClass="muted"/>

        <VBox spacing="6">
            <Label text="Email" styleClass="label"/>
            <TextField fx:id="emailField" styleClass="input"/>
            <Label fx:id="emailError" visible="false" managed="false" styleClass="field-error"/>
        </VBox>

        <VBox spacing="6">
            <Label text="Verification code" styleClass="label"/>
            <TextField fx:id="codeField" promptText="6-digit code" styleClass="input"/>
            <Label fx:id="codeError" visible="false" managed="false" styleClass="field-error"/>
        </VBox>

        <VBox spacing="6">
            <Label text="New password" styleClass="label"/>

            <StackPane>
                <PasswordField fx:id="newPassField" styleClass="input"/>
                <TextField fx:id="newPassVisibleField" styleClass="input"
                           visible="false" managed="false"/>

                <Button onAction="#handleTogglePassword"
                        styleClass="icon-btn" StackPane.alignment="CENTER_RIGHT">
                    <graphic>
                        <ImageView fx:id="eyeIcon" fitWidth="18" fitHeight="18" preserveRatio="true"/>
                    </graphic>
                </Button>
            </StackPane>

            <Label fx:id="passError" visible="false" managed="false" styleClass="field-error"/>
        </VBox>
        <VBox spacing="6">
            <Label text="Confirm password" styleClass="label"/>
            <PasswordField fx:id="confirmPassField" styleClass="input"/>
        </VBox>

        <Label fx:id="infoLabel" visible="false" managed="false" styleClass="info"/>

        <Button text="Reset Password" onAction="#handleReset">
            <styleClass>
                <String fx:value="btn-primary"/>
                <String fx:value="btn-block"/>
            </styleClass>
        </Button>

        <Label text="Back to Login" onMouseClicked="#handleBack" styleClass="link-green"/>
    </VBox>
</VBox>