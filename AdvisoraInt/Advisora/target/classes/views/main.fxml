<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1280" styleClass="app" stylesheets="@/css/admin.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.MainController">

    <left>
        <VBox prefWidth="270" styleClass="sidebar">
            <padding><Insets bottom="18" left="16" right="16" top="18" /></padding>
            <spacing>16</spacing>
            <Label styleClass="sidebar-logo-text" text="Advisora" />
            <Separator styleClass="sidebar-sep" />
            <VBox prefHeight="367.0" prefWidth="238.0" spacing="10" styleClass="nav">
                <Button styleClass="nav-btn" text="Home" />
                <Button styleClass="nav-btn" text="Gestion Utilisateurs" />
                <Button styleClass="nav-btn" text="Gestion Projets" />
                <Button styleClass="nav-btn" text="Gestion Events" />
                <Button styleClass="nav-btn" text="Gestion Stratégies" />
                <Button styleClass="nav-btn" text="Gestion Ressources" />
                <Button fx:id="btnNavInvestissements" onAction="#handleOpenInvestissements" styleClass="nav-btn" text="Gestion des Investissements" />
                <Button styleClass="nav-btn" text="Paramètres" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="profile">
                <VBox spacing="2">
                    <Label styleClass="profile-name" text="Admin" />
                    <Label styleClass="profile-role" text="ROLE_ADMIN" />
                </VBox>
            </HBox>
            <Label styleClass="sidebar-foot" text="v1.0 • Advisora" />
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" />
    </center>
</BorderPane>
