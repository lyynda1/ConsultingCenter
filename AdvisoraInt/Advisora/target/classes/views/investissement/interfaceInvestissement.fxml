<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1280" styleClass="app" stylesheets="@/css/admin.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Investissement.InvestmentListController">

    <left>
        <VBox prefWidth="270" styleClass="sidebar">
            <padding><Insets bottom="18" left="16" right="16" top="18" /></padding>
            <spacing>16</spacing>
            <Label styleClass="sidebar-logo-text" text="Advisora" />
            <Separator styleClass="sidebar-sep" />
            <VBox prefHeight="367.0" prefWidth="238.0" spacing="10" styleClass="nav">
                <Button styleClass="nav-btn" text="Home" />
                <Button styleClass="nav-btn" text="Gestion Utilisateurs" />
                <Button styleClass="nav-btn" text="Gestion Projets" />
                <Button styleClass="nav-btn" text="Gestion Events" />
                <Button styleClass="nav-btn" text="Gestion Stratégies" />
                <Button styleClass="nav-btn" text="Gestion Ressources" />
                <Button styleClass="nav-btn nav-active" text="Gestion Investissements" />
                <Button onAction="#openTransactions" styleClass="nav-btn" text="Gestion Transactions" />
                <Button styleClass="nav-btn" text="Paramètres" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="profile">
                <VBox spacing="2">
                    <Label styleClass="profile-name" text="Admin" />
                    <Label styleClass="profile-role" text="ROLE_ADMIN" />
                </VBox>
            </HBox>
            <Label styleClass="sidebar-foot" text="v1.0 • Investissements" />
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <padding><Insets bottom="14" left="18" right="18" top="14" /></padding>
            <VBox spacing="2">
                <Label styleClass="top-title" text="Gestion des Investissements" />
                <Label styleClass="top-sub" text="Ajouter, modifier et supprimer des investissements." />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="search-wrap">
                <TextField fx:id="txtSearch" onKeyReleased="#onSearch" promptText="Rechercher..." styleClass="search" />
            </HBox>
            <Button onAction="#openTransactions" styleClass="icon-btn" text="Transactions" />
            <Button onAction="#handleRefresh" styleClass="icon-btn" text="Refresh" />
            <Button styleClass="icon-btn" text="Déconnecter" />
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentHost">
            <HBox spacing="16" styleClass="page">
                <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>

                <!-- Left card: Add / Edit form -->
                <VBox prefWidth="450" spacing="14" styleClass="card">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label fx:id="formTitleLabel" styleClass="card-title" text="Add Investissement" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label styleClass="muted" text="Remplir et cliquer Ajouter" />
                    </HBox>
                    <VBox spacing="12">
                        <VBox spacing="6">
                            <Label styleClass="label" text="Commentaire" />
                            <TextArea fx:id="commentaireField" promptText="Description de l'investissement" prefRowCount="2" wrapText="true" styleClass="input" />
                        </VBox>
                        <VBox spacing="6">
                            <Label styleClass="label" text="Durée (HH:mm:ss)" />
                            <TextField fx:id="dureeField" promptText="ex: 12:00:00" styleClass="input" />
                        </VBox>
                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="label" text="Budget min" />
                                <TextField fx:id="budMinField" promptText="ex: 50000" styleClass="input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="label" text="Budget max" />
                                <TextField fx:id="budMaxField" promptText="ex: 100000" styleClass="input" />
                            </VBox>
                        </HBox>
                        <VBox spacing="6">
                            <Label styleClass="label" text="Devise" />
                            <ComboBox fx:id="currencyCombo" styleClass="combo" />
                        </VBox>
                        <HBox spacing="12">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="label" text="ID Projet" />
                                <TextField fx:id="idProjField" promptText="ex: 1" styleClass="input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="label" text="ID Utilisateur" />
                                <TextField fx:id="idUserField" promptText="ex: 1" styleClass="input" />
                            </VBox>
                        </HBox>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS" />
                    <HBox alignment="CENTER_RIGHT" spacing="10">
                        <Button onAction="#handleClearForm" styleClass="btn-outline" text="Clear" />
                        <Button fx:id="submitFormBtn" onAction="#handleSubmitForm" styleClass="btn-primary" text="Add Investissement" />
                    </HBox>
                    <Label fx:id="leftStatus" styleClass="hint" text="Prêt." />
                </VBox>

                <!-- Right card: All Investissements list -->
                <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label styleClass="card-title" text="All Investissements" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="countLabel" styleClass="pill" text="0 investissements" />
                    </HBox>
                    <ListView fx:id="investmentList" styleClass="list" VBox.vgrow="ALWAYS" />
                    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="bottom-actions">
                        <VBox spacing="6">
                            <Label styleClass="label" text="Investment ID" />
                            <TextField fx:id="idField" promptText="ID pour modifier/supprimer" styleClass="input small" />
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <Button onAction="#handleEditById" styleClass="icon-chip" text="Modifier" />
                        <Button onAction="#handleDeleteById" styleClass="icon-chip danger" text="Supprimer" />
                    </HBox>
                    <Label fx:id="rightStatus" styleClass="hint" text="Sélectionner ou saisir un ID." />
                </VBox>
            </HBox>
            <!-- Modal overlay for optional dialogs -->
            <StackPane fx:id="overlay" managed="false" styleClass="modal-overlay" visible="false">
                <VBox fx:id="modalBox" maxWidth="560" styleClass="modal-box" />
            </StackPane>
        </StackPane>
    </center>
</BorderPane>
