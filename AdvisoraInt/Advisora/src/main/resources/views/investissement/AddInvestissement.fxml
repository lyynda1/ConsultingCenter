<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Investissement.AddInvestissementDialogController"
      spacing="12" styleClass="modal-form">

    <HBox fx:id="dragHandle" alignment="CENTER_LEFT">
        <Label fx:id="dialogTitle" text="Nouvel Investissement" style="-fx-font-size: 18px; -fx-font-weight: 800;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" onAction="#close" styleClass="btn-ghost"/>
    </HBox>

    <VBox spacing="6">
        <Label text="Commentaire"/>
        <TextArea fx:id="commentaireField" promptText="Description de l'investissement" prefRowCount="3" wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Durée (HH:mm:ss)"/>
        <TextField fx:id="dureeField" promptText="ex: 12:00:00"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Budget min"/>
            <TextField fx:id="budMinField" promptText="ex: 50000"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Budget max"/>
            <TextField fx:id="budMaxField" promptText="ex: 100000"/>
        </VBox>
    </HBox>

    <VBox spacing="6">
        <Label text="Devise"/>
        <ComboBox fx:id="currencyCombo" prefWidth="200"/>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ID Projet"/>
            <TextField fx:id="idProjField" promptText="ex: 1"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ID Utilisateur"/>
            <TextField fx:id="idUserField" promptText="ex: 1"/>
        </VBox>
    </HBox>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#close" styleClass="btn-ghost"/>
        <Button fx:id="submitButton" text="Ajouter" onAction="#save" styleClass="btn-primary"/>
    </HBox>

</VBox>
