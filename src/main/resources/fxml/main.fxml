<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.advisora.Controllers.MainController">

    <!-- Top Menu Bar -->
    <top>
        <MenuBar>
            <Menu text="File">
                <MenuItem text="New Strategy" onAction="#handleNewStrategy"/>
                <MenuItem text="Exit" onAction="#handleExit"/>
            </Menu>
            <Menu text="View">
                <MenuItem text="All Strategies" onAction="#handleViewStrategies"/>
                <MenuItem text="Users" onAction="#handleViewUsers"/>
            </Menu>
            <Menu text="Help">
                <MenuItem text="About" onAction="#handleAbout"/>
            </Menu>
        </MenuBar>
    </top>

    <!-- Center Content -->
    <center>
        <VBox alignment="CENTER" spacing="20" style="-fx-background-color: #f4f4f4;">
            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <Label text="Welcome to Advisora" style="-fx-text-fill: #2c3e50;">
                <font>
                    <Font name="System Bold" size="32"/>
                </font>
            </Label>

            <Label text="Strategy Management System" style="-fx-text-fill: #7f8c8d;">
                <font>
                    <Font size="16"/>
                </font>
            </Label>

            <HBox alignment="CENTER" spacing="20">
                <padding>
                    <Insets top="30"/>
                </padding>

                <Button text="View Strategies" onAction="#handleViewStrategies"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;">
                </Button>

                <Button text="Add Strategy" onAction="#handleNewStrategy"
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;">
                </Button>

                <Button text="Manage Users" onAction="#handleViewUsers"
                        style="-fx-background-color: #9b59b6; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10 20;">
                </Button>
            </HBox>
        </VBox>
    </center>

    <!-- Bottom Status Bar -->
    <bottom>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 10;">
            <Label fx:id="statusLabel" text="Ready" style="-fx-text-fill: white;"/>
        </HBox>
    </bottom>

</BorderPane>
