<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1280" styleClass="app" stylesheets="@admin.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Admin.adminController">

    <left>
        <VBox prefWidth="270" styleClass="sidebar">
            <padding><Insets bottom="18" left="16" right="16" top="18" /></padding>
            <spacing>16</spacing>
         <ImageView fitHeight="149.0" fitWidth="230.0" pickOnBounds="true" preserveRatio="true">
            <image>
               <Image url="@icons/ADVISORA.png" />
            </image>
         </ImageView>
            <Separator styleClass="sidebar-sep" />


            <VBox prefHeight="367.0" prefWidth="238.0" spacing="10" styleClass="nav">
            <HBox>
               <children>
                  <ImageView fitHeight="44.0" fitWidth="54.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icons/home.png" />
                     </image>
                  </ImageView>
                      <Button prefHeight="60.0" prefWidth="237.0" styleClass="nav-btn" text="Home" onAction="#handleHome" />
               </children>
            </HBox>
            <HBox fx:id="navUsersRow">
               <children>
                   <Button fx:id="btnUsers" prefHeight="49.0" prefWidth="237.0" text="Gestion Utilisateurs" onAction="#handleOpenUsers">
                       <styleClass>
                           <String fx:value="nav-btn" />
                           <String fx:value="nav-active" />
                       </styleClass>
                   </Button>
               </children>
            </HBox>
            <HBox>
               <children>
                      <Button prefHeight="67.0" prefWidth="237.0" styleClass="nav-btn" text="Gestion Projets" onAction="#handleOpenProjects" />
               </children>
            </HBox>
            <HBox>
               <children>
                      <Button prefHeight="58.0" prefWidth="237.0" styleClass="nav-btn" text="Gestion Events" />
               </children>
            </HBox>
            <HBox fx:id="navStrategiesRow">
               <children>
                      <Button fx:id="btnStrategies" prefHeight="54.0" prefWidth="237.0" styleClass="nav-btn" text="Gestion Strategies" onAction="#handleOpenStrategies" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="264.0">
               <children>
                  <Button prefHeight="54.0" prefWidth="237.0" styleClass="nav-btn" text="Gestion Ressources" onAction="#handleOpenResourceModule" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="112.0">
               <children>
                  <Button prefHeight="67.0" prefWidth="237.0" styleClass="nav-btn" text="Gestion Investissements" onAction="#handleOpenReservations" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="317.0">
               <children>
                  <ImageView fitHeight="45.0" fitWidth="53.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@icons/GEAR.png" />
                     </image>
                  </ImageView>
                  <Button prefHeight="67.0" prefWidth="237.0" styleClass="nav-btn" text="Parametres" />
               </children>
            </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="profile">
            <ImageView fitHeight="40.0" fitWidth="39.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@icons/profile.png" />
               </image>
            </ImageView>
                <VBox spacing="2">
                    <Label styleClass="profile-name" text="Admin" />
                    <Label styleClass="profile-role" text="ROLE_ADMIN" />
                </VBox>
            </HBox>

            <Label styleClass="sidebar-foot" text="v1.0 - Users module" />
        </VBox>
    </left>

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
            <padding><Insets bottom="14" left="18" right="18" top="14" /></padding>

            <VBox spacing="2">
                <Label styleClass="top-title" text="Admin Dashboard" />
                <Label styleClass="top-sub" text="Add, manage and remove users quickly." />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="search-wrap">
            <ImageView fitHeight="32.0" fitWidth="34.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@icons/search.png" />
               </image>
            </ImageView>
                <TextField fx:id="searchField" promptText="Search..." styleClass="search" />
            </HBox>

            <Button styleClass="icon-btn" text="Refresh" onAction="#handleRefresh">
                <tooltip>
                    <Tooltip text="Refresh" />
                </tooltip>
            </Button>

            <Button styleClass="icon-btn" text="Deconnecter" onAction="#handleLogout" />
        </HBox>
    </top>

    <center>
        <StackPane fx:id="contentHost">
        <HBox spacing="16" styleClass="page">
            <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>

            <VBox prefWidth="450" spacing="14" styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="card-title" text="Add User" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="muted" text="Fill and click Add" />
                </HBox>

                <VBox spacing="12">
                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="label" text="FirstName"/>
                            <TextField fx:id="nomField" promptText="ex: Ben Ali" styleClass="input"/>
                            <Label fx:id="nomError" styleClass="field-error" text="" visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="label" text="LastName"/>
                            <TextField fx:id="prenomField" promptText="ex: Ben Ali" styleClass="input"/>
                            <Label fx:id="prenomError" styleClass="field-error" text="" visible="false" managed="false"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label styleClass="label" text="Email"/>
                        <TextField fx:id="emailField" promptText="ex: aa@example.com" styleClass="input"/>
                        <Label fx:id="emailError" styleClass="field-error" text="" visible="false" managed="false"/>
                    </VBox>

                    <HBox spacing="12">
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="label" text="CIN"/>
                            <TextField fx:id="cinField" promptText="ex: 12345678" styleClass="input"/>
                            <Label fx:id="cinError" styleClass="field-error" text="" visible="false" managed="false"/>
                        </VBox>
                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                            <Label styleClass="label" text="Phone Number"/>
                            <TextField fx:id="telField" promptText="ex:+216 XX-XXX-XXX" styleClass="input"/>
                            <Label fx:id="telError" styleClass="field-error" text="" visible="false" managed="false"/>
                        </VBox>
                    </HBox>

                    <VBox spacing="6">
                        <Label styleClass="label" text="Birth Date"/>
                        <TextField fx:id="dateNField" promptText="yyyy-MM-dd" styleClass="input"/>
                        <Label fx:id="dateNError" styleClass="field-error" text="" visible="false" managed="false"/>

                    </VBox>
               <VBox layoutX="10.0" layoutY="248.0" spacing="6">
                  <children>
                     <Label styleClass="label" text="Password" />
                     <PasswordField fx:id="passwordField" promptText="********" styleClass="input" />
                      <Label fx:id="passwordError" styleClass="field-error" text="" visible="false" managed="false"/>
      
                          <HBox spacing="12">
                              <VBox spacing="6" HBox.hgrow="ALWAYS">
                                  <Label styleClass="label" text="Role" />
                                  <ComboBox fx:id="roleCombo" promptText="Select role" styleClass="combo" />
                                  <Label fx:id="roleError" styleClass="field-error" text="" visible="false" managed="false"/>
                              </VBox>
                              <VBox spacing="6" HBox.hgrow="ALWAYS">
                                  <Label styleClass="label" text="Expertise Area" />
                                  <TextField fx:id="expertiseField" promptText="ex: Finance" styleClass="input" />
                                  <Label fx:id="expertiseError" styleClass="field-error" text="" visible="false" managed="false"/>
                              </VBox>
                          </HBox>
                  </children>
               </VBox>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <Button fx:id="clearBtn" cancelButton="true" onAction="#handleClear" prefHeight="30.0" prefWidth="61.0" styleClass="btn-outline" text="Clear" />
                    <Button fx:id="addBtn" onAction="#handleAddUser" styleClass="btn-primary" text="Add User" />
                </HBox>

                <Label fx:id="leftStatus" styleClass="hint" text="Ready." />
            </VBox>

            <VBox spacing="14" styleClass="card" HBox.hgrow="ALWAYS">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label styleClass="card-title" text="All Users" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="countLabel" styleClass="pill" text="0 users" />
                </HBox>

                <ListView fx:id="usersList" styleClass="list" VBox.vgrow="ALWAYS" />

                <HBox alignment="CENTER_LEFT" spacing="12" styleClass="bottom-actions">
                    <VBox spacing="6">
                        <Label styleClass="label" text="User ID" />
                        <TextField fx:id="idField" promptText="Enter ID to modify/delete" styleClass="input small" />
                    </VBox>

                    <Region HBox.hgrow="ALWAYS" />
                    <StackPane fx:id="modifyBtn" styleClass="icon-chip" onMouseClicked="#handleModifyById" >
                        <ImageView fitHeight="30" fitWidth="30" preserveRatio="true">
                            <image>
                                <Image url="@icons/edit.jpg" />
                            </image>
                        </ImageView>
                    </StackPane>

                    <StackPane fx:id="deleteBtn" styleClass="icon-chip danger" onMouseClicked="#handleDeleteById">
                        <ImageView fitHeight="30" fitWidth="30" preserveRatio="true">
                            <image>
                                <Image url="@icons/delete.jpg" />
                            </image>
                        </ImageView>
                    </StackPane>


                </HBox>

                <Label fx:id="rightStatus" styleClass="hint" text="Select a user or type an ID." />
            </VBox>
        </HBox>
        </StackPane>
    </center>

</BorderPane>

