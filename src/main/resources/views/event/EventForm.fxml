<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Event.EventFormController"
      stylesheets="@../style/forms_proj.css"
      styleClass="form-root">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Event Form" styleClass="form-title"/>

    <GridPane hgap="8" vgap="8">
        <Label text="Titre" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTitle" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtDescription" prefRowCount="3" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Date debut" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <DatePicker fx:id="dateStart" prefWidth="180"/>
            <TextField fx:id="txtStartTime" promptText="HH:mm" prefWidth="100"/>
        </HBox>

        <Label text="Date fin" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="3" GridPane.columnIndex="1">
            <DatePicker fx:id="dateEnd" prefWidth="180"/>
            <TextField fx:id="txtEndTime" promptText="HH:mm" prefWidth="100"/>
        </HBox>

        <Label text="Organisateur" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtOrganiser" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Capacite" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCapacity" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

        <Label text="Lieu" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <TextField fx:id="txtLocation" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="8" styleClass="form-actions">
        <Button text="Save" onAction="#onSave" styleClass="btn-save"/>
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-cancel"/>
    </HBox>
</VBox>
