<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane fx:id="rootPane"
           styleClass="app"
           stylesheets="@/GUI/Admin/admin.css"
           xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.advisora.GUI.InterfaceGeneralController">

    <!-- ================= MAIN LAYOUT ================= -->
    <BorderPane prefHeight="720" prefWidth="1280">

        <!-- ================= LEFT SIDEBAR ================= -->
        <left>
            <VBox prefWidth="270" styleClass="sidebar">
                <padding>
                    <Insets bottom="18" left="16" right="16" top="18" />
                </padding>
                <spacing>16</spacing>

                <ImageView fitHeight="149" fitWidth="230" preserveRatio="true">
                    <image>
                        <Image url="@/GUI/Admin/icons/ADVISORA.png" />
                    </image>
                </ImageView>

                <Separator styleClass="sidebar-sep" />

                <!-- Navigation -->
                <VBox spacing="10" styleClass="nav">
                    <Button fx:id="homeBtn" onAction="#handleOpenHome" prefWidth="237" styleClass="nav-btn" text="Home" />
                    <Button fx:id="usersBtn" onAction="#handleOpenUsers" prefWidth="237" styleClass="nav-btn" text="Gestion Utilisateurs" />
                    <Button fx:id="ressourceBtn" onAction="#handleOpenRessource" prefWidth="237" styleClass="nav-btn" text="Gestion Ressources" />
                    <Button fx:id="projectsBtn" onAction="#handleOpenProjects" prefWidth="237" styleClass="nav-btn" text="Gestion Projets" />
                    <Button fx:id="eventsBtn" onAction="#handleOpenEvents" prefWidth="237" styleClass="nav-btn" text="Evenements" />
                    <Button fx:id="strategiesBtn" onAction="#handleOpenStrategies" prefWidth="237" styleClass="nav-btn" text="Gestion Stratégies" />
                    <Button fx:id="investissementsBtn" onAction="#handleOpenInvestissements" prefWidth="237" styleClass="nav-btn" text="Gestion Investissements" />
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- PROFILE CLICK AREA -->
                <HBox alignment="CENTER_LEFT" onMouseClicked="#openProfile" spacing="10" styleClass="profile">
                    <ImageView fx:id="profileImageView" fitHeight="40" fitWidth="40" preserveRatio="true" />
                    <VBox spacing="2">
                        <Label fx:id="nomUser" styleClass="profile-name" text="Admin" />
                        <Label fx:id="roleStatut" styleClass="profile-role" text="ROLE_ADMIN" />
                    </VBox>
                </HBox>

                <Label styleClass="sidebar-foot" text="v1.0 • Users module" />
            </VBox>
        </left>

        <!-- ================= TOP BAR ================= -->
        <top>
            <HBox fx:id="topBar" alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
                <padding>
                    <Insets bottom="14" left="18" right="18" top="14" />
                </padding>

                <VBox spacing="2">
                    <Label styleClass="top-title" text="Bienvenue dans Advisora" />
                    <Label styleClass="top-sub" text="Votre succès est notre mission " />
                </VBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Notification Button with Badge -->
                <HBox alignment="CENTER">
                    <children>
                        <Button fx:id="notificationButton"
                                onAction="#handleNotificationClick"
                                prefHeight="35" prefWidth="40"
                                styleClass="icon-btn">
                            <graphic>
                                <ImageView fitHeight="24" fitWidth="24" preserveRatio="true">
                                    <image>
                                        <Image url="@../Assets/bell.png" />
                                    </image>
                                </ImageView>
                            </graphic>
                        </Button>

                        <!-- Notification Badge -->
                        <StackPane layoutX="-10" layoutY="-10">
                            <children>
                                <Circle fx:id="notificationBadge" radius="10" fill="red" visible="false" />
                                <Label fx:id="notifCount"
                                       textFill="white"
                                       style="-fx-font-weight: bold; -fx-font-size: 10;"
                                       visible="false" />
                            </children>
                        </StackPane>
                    </children>
                </HBox>

                <Button onAction="#handleLogout" styleClass="icon-btn" text="Logout" />
            </HBox>
        </top>

        <!-- ================= CENTER CONTENT ================= -->
        <center>
            <StackPane fx:id="contentHost">
                <AnchorPane>
                    <children>
                        <Text layoutX="79" layoutY="75" text="Bienvenue">
                            <font>
                                <Font name="System Bold" size="34" />
                            </font>
                        </Text>
                        <Text layoutX="79" layoutY="114" text="Que souhaitez-vous faire aujourd'hui?" wrappingWidth="500">
                            <font>
                                <Font size="22" />
                            </font>
                        </Text>
                    </children>
                </AnchorPane>
            </StackPane>
        </center>

    </BorderPane>

    <!-- ================= POPUP LAYER (notifications, dropdowns) ================= -->
    <Pane fx:id="popupLayer" pickOnBounds="false" />

    <!-- ================= OVERLAY (PROFILE MODAL) ================= -->
    <StackPane fx:id="overlay"
               managed="false"
               visible="false"
               style="-fx-background-color: rgba(0,0,0,0.45);">
        <VBox fx:id="modalBox" alignment="CENTER" spacing="20" />
    </StackPane>

</StackPane>
