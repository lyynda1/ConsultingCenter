<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Investissement.AddInvestissementDialogController"
      spacing="14" styleClass="dialog-card">

    <HBox fx:id="dragHandle" alignment="CENTER_LEFT" spacing="10" styleClass="dialog-header">
        <Label fx:id="dialogTitle" text="Nouvel Investissement" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✖" onAction="#close" styleClass="btn-ghost"/>
    </HBox>

    <VBox spacing="6">
        <Label text="Commentaire"/>
        <TextArea fx:id="commentaireField" promptText="Description de l'investissement" prefRowCount="3" wrapText="true"/>
    </VBox>

    <VBox spacing="6">
        <Label text="Durée"/>
        <HBox spacing="8">
            <TextField fx:id="dureeField" promptText="ex: 12"/>
            <ComboBox fx:id="dureeUnitCombo" prefWidth="140" promptText="Unité"/>
        </HBox>
    </VBox>

    <HBox spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Budget min"/>
            <TextField fx:id="budMinField" promptText="ex: 50000"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="Budget max"/>
            <TextField fx:id="budMaxField" promptText="ex: 100000"/>
        </VBox>
    </HBox>

    <VBox spacing="6">
        <Label text="Devise"/>
        <ComboBox fx:id="currencyCombo" prefWidth="200"/>
    </VBox>

    <!-- Pour admin/gerant : ID Projet et ID Utilisateur -->
    <HBox fx:id="adminProjectRow" spacing="12">
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ID Projet"/>
            <TextField fx:id="idProjField" promptText="ex: 1"/>
        </VBox>
        <VBox spacing="6" HBox.hgrow="ALWAYS">
            <Label text="ID Utilisateur"/>
            <TextField fx:id="idUserField" promptText="ex: 1"/>
        </VBox>
    </HBox>

    <!-- Pour client : choix du projet par son nom -->
    <VBox fx:id="clientProjectRow" spacing="6" visible="false" managed="false">
        <Label text="Nom du projet"/>
        <ComboBox fx:id="projectNameCombo" prefWidth="200" promptText="Choisir un projet existant"/>
    </VBox>

    <HBox spacing="8" alignment="CENTER_RIGHT">
        <Button text="Annuler" onAction="#close" styleClass="btn-ghost"/>
        <Button fx:id="submitButton" text="Ajouter" onAction="#save" styleClass="btn-primary"/>
    </HBox>
</VBox>

