<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.advisora.GUI.Transaction.TransactionHistoryController">

    <top>
        <VBox spacing="10" styleClass="header">
            <padding>
                <Insets top="12" right="18" bottom="12" left="18"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Historique des Transactions" styleClass="title">
                    <font>
                        <Font name="System Bold" size="22.0"/>
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Fermer" onAction="#onClose" styleClass="btn-ghost"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="8" styleClass="content">
            <padding>
                <Insets top="10" right="18" bottom="18" left="18"/>
            </padding>

            <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60.0"/>
                    <TableColumn fx:id="colDate" text="Date" prefWidth="140.0"/>
                    <TableColumn fx:id="colMontant" text="Montant" prefWidth="120.0"/>
                    <TableColumn fx:id="colType" text="Type" prefWidth="160.0"/>
                    <TableColumn fx:id="colStatut" text="Statut" prefWidth="120.0"/>
                    <TableColumn fx:id="colInv" text="Investissement" prefWidth="220.0"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>

