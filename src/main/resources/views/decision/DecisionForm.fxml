<?xml version="1.0" encoding="UTF-8"?>
<!-- ADVISORA STRUCTURE COMMENT
 param($m) 'File: ' + ($m.Groups[1].Value -replace '\\','/') 
Role: Decision module UI layout (FXML) -->


<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Project.DecisionFormController" style="-fx-padding: 12;">
    <GridPane hgap="8" vgap="8">
        <Label text="Status" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ChoiceBox fx:id="choiceStatus" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Description" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextArea fx:id="txtDescription" prefRowCount="4" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Decision Date" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <DatePicker fx:id="dateDecision" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Project ID" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtProjectId" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="8">
        <Button text="Save" onAction="#onSave"/>
        <Button text="Cancel" onAction="#onCancel"/>
    </HBox>
</VBox>
