<?xml version="1.0" encoding="UTF-8"?>
<!-- ADVISORA STRUCTURE COMMENT
 param($m) 'File: ' + ($m.Groups[1].Value -replace '\\','/') 
Role: Decision module UI layout (FXML) -->


<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Project.DecisionListController">
    <top>
        <HBox spacing="8">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <Button text="Add" onAction="#onAdd"/>
            <Button fx:id="btnEdit" text="Edit" onAction="#onEdit"/>
            <Button fx:id="btnDelete" text="Delete" onAction="#onDelete"/>
            <Button text="Refresh" onAction="#onRefresh"/>
            <Label text="Project ID"/>
            <TextField fx:id="txtProjectFilter" prefWidth="90"/>
            <Button text="Filter" onAction="#onApplyFilter"/>
            <Button text="Projects" onAction="#onOpenProjects"/>
        </HBox>
    </top>

    <center>
        <VBox>
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>
            <TableView fx:id="decisionTable">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="70"/>
                    <TableColumn fx:id="colStatus" text="Status" prefWidth="110"/>
                    <TableColumn fx:id="colDescription" text="Description" prefWidth="320"/>
                    <TableColumn fx:id="colProjectId" text="Project ID" prefWidth="100"/>
                    <TableColumn fx:id="colUserId" text="Manager ID" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
