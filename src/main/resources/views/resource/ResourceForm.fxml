<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Ressource.ResourceFormController"
      stylesheets="@../style/forms_proj.css"
      styleClass="form-root">
    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>

    <Label text="Resource Form" styleClass="form-title"/>

    <GridPane hgap="8" vgap="8">
        <Label text="Fournisseur" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboSupplier" prefWidth="260" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Nom" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtName" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Prix" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPrice" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Quantite" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtQty" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Statut" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="comboStatus" prefWidth="180" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
    </GridPane>

    <HBox spacing="8" styleClass="form-actions">
        <Button text="Save" onAction="#onSave" styleClass="btn-save"/>
        <Button text="Cancel" onAction="#onCancel" styleClass="btn-cancel"/>
        <Button fx:id="btnDelete" text="Delete" onAction="#onDelete" styleClass="btn-delete"/>
    </HBox>
</VBox>
