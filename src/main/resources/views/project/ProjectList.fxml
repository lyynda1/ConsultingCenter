<?xml version="1.0" encoding="UTF-8"?>
<!-- ADVISORA STRUCTURE COMMENT
 param($m) 'File: ' + ($m.Groups[1].Value -replace '\\','/')
Role: Project module UI layout (FXML/CSS) -->

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.advisora.GUI.Project.ProjectListController">

    <!-- ============== YOUR EXISTING PAGE ============== -->
    <BorderPane stylesheets="@../style/project-list.css"
                styleClass="page">

        <fx:define>
            <ToggleGroup fx:id="statusGroup"/>
        </fx:define>

        <top>
            <VBox spacing="12" styleClass="header">
                <padding>
                    <Insets top="18" right="18" bottom="12" left="18"/>
                </padding>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label text="%project.page.title" styleClass="title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="btnStats" text="%project.btn.stats" onAction="#onOpenStats" styleClass="btn-ghost"/>
                    <Button fx:id="btnTop10" text="%project.btn.top10" onAction="#onOpenTop10" styleClass="btn-ghost"/>
                    <Button fx:id="btnEstimate" text="%project.btn.estimate" onAction="#onOpenEstimation" styleClass="btn-ghost"/>
                    <Button fx:id="btnExportPdf" text="%project.btn.exportPdf" onAction="#onExportPdf">
                        <styleClass>
                            <String fx:value="btn-primary"/>
                            <String fx:value="export-btn"/>
                        </styleClass>
                    </Button>
                    <Button fx:id="btnUsers" text="%project.btn.users" onAction="#onOpenUsers" styleClass="btn-ghost"/>
                    <Button fx:id="btnNewProject" text="%project.btn.new" onAction="#onAdd" styleClass="btn-primary"/>
                </HBox>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <HBox spacing="8" styleClass="tabs">
                        <ToggleButton fx:id="tabAll" text="%project.tab.all" onAction="#onTabAll" toggleGroup="$statusGroup" selected="true" styleClass="tab"/>
                        <ToggleButton fx:id="tabValid" text="%project.tab.valid" onAction="#onTabValid" toggleGroup="$statusGroup" styleClass="tab"/>
                        <ToggleButton fx:id="tabPending" text="%project.tab.pending" onAction="#onTabPending" toggleGroup="$statusGroup" styleClass="tab"/>
                        <ToggleButton fx:id="tabRefused" text="%project.tab.refused" onAction="#onTabRefused" toggleGroup="$statusGroup" styleClass="tab"/>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS"/>

                    <TextField fx:id="txtSearch"
                               promptText="%project.search.prompt"
                               onKeyReleased="#onSearch"
                               styleClass="search"/>

                    <MenuButton text="Filtrer" styleClass="btn-ghost">
                        <items>
                            <MenuItem text="%project.sort.budgetAsc" onAction="#onSortBudgetAsc"/>
                            <MenuItem text="%project.sort.budgetDesc" onAction="#onSortBudgetDesc"/>
                            <SeparatorMenuItem/>
                            <MenuItem text="%project.sort.progressAsc" onAction="#onSortAvancementAsc"/>
                            <MenuItem text="%project.sort.progressDesc" onAction="#onSortAvancementDesc"/>
                        </items>
                    </MenuButton>
                </HBox>

            </VBox>
        </top>

        <center>
            <VBox styleClass="content" fillWidth="true">
                <padding>
                    <Insets top="14" right="18" bottom="18" left="18"/>
                </padding>
                <ListView fx:id="projectList" styleClass="card-list" VBox.vgrow="ALWAYS"/>
            </VBox>
        </center>
    </BorderPane>

    <!-- ============== OVERLAY MODAL LAYER ============== -->
    <StackPane fx:id="overlay"
               visible="false"
               managed="false"
               pickOnBounds="true"
               styleClass="overlay">

        <!-- background click closes the dialog -->
        <Region styleClass="overlay-bg" onMouseClicked="#closeDialog"/>

        <!-- modal content container -->
        <VBox fx:id="modalBox" styleClass="modal-box"/>
    </StackPane>

</StackPane>
