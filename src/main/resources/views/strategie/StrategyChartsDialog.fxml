<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="836.0" prefWidth="1167.0" styleClass="dialog-root" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Strategie.StrategyChartsDialogController">

    <VBox prefHeight="727.0" prefWidth="1068.0" spacing="12" styleClass="dialog-container" AnchorPane.bottomAnchor="7.0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0">

        <padding><Insets bottom="18" left="18" right="18" top="18" /></padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="10">
            <Label fx:id="dragHandle" styleClass="dialog-title" text="Strategic Portfolio Chart" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#onClose" styleClass="btn-close" text="✕" />
        </HBox>

        <!-- Filters row -->
        <HBox alignment="CENTER_LEFT" spacing="10" styleClass="chart-filters">
            <Label styleClass="dialog-subtitle" text="Filtres:" />

            <ComboBox fx:id="cmbStatus" prefWidth="170" promptText="Statut" />
            <CheckBox fx:id="chkHasSwot" text="SWOT uniquement" />
            <Label text="ROI min:" />
            <Spinner fx:id="spMinRoi" prefWidth="120" />
            <Label text="Risk max:" />
            <Spinner fx:id="spMaxRisk" prefWidth="120" />

            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#onResetFilters" styleClass="btn-ghost" text="Réinitialiser" />
            <Button onAction="#onApplyFilters" styleClass="btn-primary" text="Actualiser" />
        </HBox>

        <!-- Main content -->
        <HBox prefHeight="561.0" prefWidth="1022.0" spacing="14" VBox.vgrow="ALWAYS">

            <!-- ✅ Chart zone with correctly anchored overlay labels -->
            <AnchorPane prefHeight="558.0" prefWidth="819.0" styleClass="chart-holder" HBox.hgrow="ALWAYS">

                <StackPane fx:id="chartHolder" layoutX="60.0" layoutY="87.0" prefHeight="483.0" prefWidth="777.0" AnchorPane.bottomAnchor="112.0" AnchorPane.leftAnchor="60.0" AnchorPane.rightAnchor="60.0" AnchorPane.topAnchor="87.0" />

                <VBox fx:id="qTopLeft" maxWidth="240" prefWidth="240" styleClass="quad-label" AnchorPane.leftAnchor="12" AnchorPane.topAnchor="12">
                    <Label styleClass="quad-title" text="⭐ meilleurs paris" />
                    <Label styleClass="quad-sub" text="ROI élevé • risque faible" />
                </VBox>

                <VBox fx:id="qTopRight" maxWidth="240" prefWidth="240" styleClass="quad-label" AnchorPane.rightAnchor="12" AnchorPane.topAnchor="12">
                    <Label styleClass="quad-title" text="⚠ retour élevé / risque élevé" />
                    <Label styleClass="quad-sub" text="ROI élevé • risque élevé" />
                </VBox>

                <VBox fx:id="qBottomLeft" maxWidth="240" prefWidth="240" styleClass="quad-label" AnchorPane.bottomAnchor="12" AnchorPane.leftAnchor="12">
                    <Label styleClass="quad-title" text="🟢 Sans danger / faible croissance" />
                    <Label styleClass="quad-sub" text="ROI faible • risque faible" />
                </VBox>

                <VBox fx:id="qBottomRight" maxWidth="240" prefWidth="240" styleClass="quad-label" AnchorPane.bottomAnchor="12" AnchorPane.rightAnchor="12">
                    <Label styleClass="quad-title" text="🚨 Risquée et faible" />
                    <Label styleClass="quad-sub" text="ROI faible • risque élevé" />
                </VBox>

            </AnchorPane>

            <!-- Legend -->
            <VBox prefWidth="220" spacing="10" styleClass="legend-panel">
                <Label styleClass="legend-title" text="Légende" />

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="legend-dot dot-accepted" />
                    <Label text="Acceptée" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="legend-dot dot-progress" />
                    <Label text="En cours" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="legend-dot dot-pending" />
                    <Label text="En attente" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region styleClass="legend-dot dot-refused" />
                    <Label text="Refusée" />
                </HBox>

                <Separator />

                <Label styleClass="legend-sub" text="Taille du point = Budget" />
                <Label styleClass="legend-sub" text="Survol → détails" />
                <Label styleClass="legend-sub" text="Clic → ouvrir stratégie" />
            </VBox>
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="10">
            <Button onAction="#onClose" styleClass="btn-ghost" text="Fermer" />
        </HBox>

    </VBox>
</AnchorPane>
