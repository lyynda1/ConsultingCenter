<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.advisora.GUI.Strategie.AddStrategieDialogController">

    <!-- ✅ Dialog content goes INSIDE a VBox -->
    <VBox prefHeight="400" prefWidth="400" spacing="14" styleClass="dialog-card">

        <HBox fx:id="dragHandle" alignment="CENTER_LEFT" spacing="10" styleClass="dialog-header">
            <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: 800;" text="Nouvelle Stratégie" />
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#close" styleClass="btn-ghost" text="✕" />
        </HBox>

        <VBox spacing="6">
            <Label text="Nom" />
            <TextField fx:id="nomField" promptText="Nom de la stratégie" />
        </VBox>

        <VBox spacing="6">
            <Label text="Projet" />
            <ComboBox fx:id="projetCombo" promptText="Choisir un projet" />
        </VBox>

        <VBox spacing="6">
            <Label text="Type" />
            <ComboBox fx:id="typeCombo" promptText="Choisir un type" />
        </VBox>

        <VBox spacing="6">
            <Label text="Budget total" />
            <TextField fx:id="budgetTotalField" promptText="ex: 100000" />
        </VBox>

        <VBox spacing="6">
            <Label text="Gain estimé" />
            <TextField fx:id="gainEstimeField" promptText="ex: 50000" />
        </VBox>

        <VBox spacing="6">
            <Label text="Statut" />
            <ComboBox fx:id="statutCombo" />
        </VBox>

        <Label text="Durée du terme" />

        <HBox spacing="8" alignment="CENTER_LEFT">
            <TextField fx:id="terme" promptText="Durée en nombre de jours seulement" HBox.hgrow="ALWAYS"/>
            <Text text="jours" />
        </HBox>

        <HBox alignment="CENTER_RIGHT" spacing="6">
            <Button onAction="#close" styleClass="btn-ghost" text="Annuler" />
            <Button fx:id="saveBtn" onAction="#save" styleClass="btn-primary" text="Ajouter" />
        </HBox>

    </VBox>

    <!-- ✅ Overlay ABOVE the dialog -->
    <StackPane fx:id="overlay" visible="false" managed="false"
               style="-fx-background-color: rgba(0,0,0,0.25);">
        <ProgressIndicator maxWidth="80" maxHeight="80"/>
    </StackPane>

</StackPane>