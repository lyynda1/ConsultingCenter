<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox prefHeight="400" prefWidth="400" spacing="14" styleClass="dialog-card" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Strategie.AddStrategieDialogController">

    <HBox fx:id="dragHandle" alignment="CENTER_LEFT" spacing="10" styleClass="dialog-header">
        <Label fx:id="titleLabel" style="-fx-font-size: 18px; -fx-font-weight: 800;" text="Nouvelle Stratégie" />
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#close" styleClass="btn-ghost" text="✕" />
    </HBox>

    <VBox spacing="6">
        <Label text="Nom" />
        <TextField fx:id="nomField" promptText="Nom de la stratégie" />
    </VBox>
    <VBox spacing="6">
        <Label text="Projet" />
        <ComboBox fx:id="projetCombo" promptText="Choisir un projet" />
    </VBox>
    <VBox spacing="6">
        <Label text="Type" />
        <ComboBox fx:id="typeCombo" promptText="Choisir un type" />
    </VBox>
    <VBox spacing="6">
        <Label text="Budget total" />
        <TextField fx:id="budgetTotalField" promptText="ex: 100000" />
    </VBox>
    <VBox spacing="6">
        <Label text="Gain estimé" />
        <TextField fx:id="gainEstimeField" promptText="ex: 50000" />
    </VBox>



    <VBox spacing="6">
        <Label text="Statut" />
        <ComboBox fx:id="statutCombo" />
    </VBox>
    <VBox spacing="6" />
     <Label text="Durée du terme" />

    <VBox spacing="6">
      <HBox prefHeight="100.0" prefWidth="400.0">
         <children>
              <TextField fx:id="terme" prefHeight="25.0" prefWidth="331.0" promptText="Durée en nombre de jours seulement" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="     jours" />
         </children>
      </HBox>
    </VBox>


    <HBox alignment="CENTER_RIGHT" spacing="6">
        <Button onAction="#close" styleClass="btn-ghost" text="Annuler" />
        <Button onAction="#save" styleClass="btn-primary" text="Ajouter" />
    </HBox>

</VBox>
