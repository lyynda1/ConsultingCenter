<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.advisora.GUI.Strategie.StrategieListController"
            stylesheets="@/css/strategie-list.css"
            styleClass="page">

    <top>
        <VBox spacing="12" styleClass="header">
            <padding>
                <Insets top="18" right="18" bottom="12" left="18"/>
            </padding>

            <!-- Title + actions -->
            <HBox alignment="CENTER_LEFT">
                <Label text="Gestion des Stratégies" styleClass="title"/>
                <Region HBox.hgrow="ALWAYS"/>

                <Button text="+ Nouvelle Stratégie"
                        onAction="#nouvelleStrategie"
                        styleClass="btn-primary"/>
            </HBox>

            <!-- Search + filter -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Region HBox.hgrow="ALWAYS"/>

                <TextField fx:id="txtSearch"
                           promptText="Rechercher une stratégie..."
                           onKeyReleased="#onSearch"
                           styleClass="search"/>

                <MenuButton text="Filtrer" styleClass="btn-ghost">
                    <items>
                        <MenuItem text="Nom A → Z" onAction="#onSortNomAsc"/>
                        <MenuItem text="Nom Z → A" onAction="#onSortNomDesc"/>
                        <SeparatorMenuItem/>
                        <MenuItem text="Date récente" onAction="#onSortDateDesc"/>
                        <MenuItem text="Date ancienne" onAction="#onSortDateAsc"/>
                    </items>
                </MenuButton>
            </HBox>

            <!-- Small stats row (optional, you had it) -->
            <HBox spacing="16" styleClass="stats">
                <VBox spacing="4" styleClass="stat-card">
                    <Label text="Total Stratégies" styleClass="stat-label"/>
                    <Label fx:id="lblTotalStrategies" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card">
                    <Label text="En attente d'approbation" styleClass="stat-label"/>
                    <Label fx:id="lblPending" text="0" styleClass="stat-value"/>
                </VBox>

                <VBox spacing="4" styleClass="stat-card">
                    <Label text="Taux de réussite" styleClass="stat-label"/>
                    <Label fx:id="lblSuccess" text="0%" styleClass="stat-value"/>
                </VBox>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox styleClass="content" fillWidth="true">
            <padding>
                <Insets top="14" right="18" bottom="18" left="18"/>
            </padding>

            <!-- This replaces the TableView -->
            <ListView fx:id="strategieList" styleClass="card-list" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

</BorderPane>
