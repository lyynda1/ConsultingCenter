<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.MenuButton?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="pageRoot" styleClass="page-root" stylesheets="@/css/strategie-list.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Strategie.StrategieListController">

    <!-- MAIN PAGE -->
    <BorderPane fx:id="mainPane" styleClass="page">

        <top>
            <VBox spacing="12" styleClass="header">
                <padding>
                    <Insets bottom="12" left="18" right="18" top="18" />
                </padding>

                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="title" text="Gestion des Stratégies">
                  <font>
                     <Font name="System Bold" size="31.0" />
                  </font></Label>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button onAction="#nouvelleStrategie" styleClass="btn-primary" text="+ Nouvelle Stratégie" />
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Region HBox.hgrow="ALWAYS" />
                    <TextField fx:id="txtSearch" onKeyReleased="#onSearch" promptText="Rechercher une stratégie..." styleClass="search" />
                    <MenuButton styleClass="btn-ghost" text="Filtrer">
                        <items>
                            <MenuItem onAction="#onSortNomAsc" text="Nom A → Z" />
                            <MenuItem onAction="#onSortNomDesc" text="Nom Z → A" />
                            <SeparatorMenuItem />
                            <MenuItem onAction="#onSortDateDesc" text="Date récente" />
                            <MenuItem onAction="#onSortDateAsc" text="Date ancienne" />

                        </items>
                    </MenuButton>
                </HBox>

                <!-- Stats row (your 3 boxes) -->
                <HBox fillHeight="true" spacing="16" styleClass="stats">

                    <VBox maxWidth="1.7976931348623157E308" prefWidth="320" spacing="8" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card" />
                            <String fx:value="stat-total" />
                        </styleClass>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Label text="📈" textFill="#ea7527">
                           <font>
                              <Font size="20.0" />
                           </font></Label>
                            </StackPane>
                            <Label styleClass="stat-label" text="Total Stratégies" />
                        </HBox>
                        <Label fx:id="lblTotalStrategies" styleClass="stat-value" text="0" />
                    </VBox>

                    <VBox maxWidth="1.7976931348623157E308" prefWidth="320" spacing="8" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card" />
                            <String fx:value="stat-pending" />
                        </styleClass>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Label text="👥" textFill="#ea7527">
                           <font>
                              <Font size="20.0" />
                           </font></Label>
                            </StackPane>
                            <Label styleClass="stat-label" text="En attente d'approbation" />
                        </HBox>
                        <Label fx:id="lblPending" styleClass="stat-value" text="0" />
                    </VBox>

                    <VBox maxWidth="1.7976931348623157E308" prefWidth="320" spacing="8" HBox.hgrow="ALWAYS">
                        <styleClass>
                            <String fx:value="stat-card" />
                            <String fx:value="stat-success" />
                        </styleClass>
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <StackPane>
                                <Label text="✅" textFill="#ea7527">
                           <font>
                              <Font size="20.0" />
                           </font></Label>
                            </StackPane>
                            <Label styleClass="stat-label" text="Taux de réussite" />
                        </HBox>
                        <Label fx:id="lblSuccess" styleClass="stat-value" text="0%" />
                    </VBox>

                </HBox>
            </VBox>
        </top>

        <center>
            <VBox fillWidth="true" styleClass="content">
                <padding>
                    <Insets bottom="18" left="18" right="18" top="14" />
                </padding>

                <ListView fx:id="strategieList" styleClass="card-list" VBox.vgrow="ALWAYS" />
            </VBox>
        </center>
    </BorderPane>

    <!-- ✅ OVERLAY ABOVE EVERYTHING -->
    <StackPane fx:id="overlay" visible="false" managed="false" styleClass="overlay">
        <VBox fx:id="modalBox" styleClass="dialog-host"/>
    </StackPane>


</StackPane>
