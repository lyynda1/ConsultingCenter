<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox maxWidth="700" minWidth="460" prefWidth="600" spacing="12" styleClass="dialog-card" stylesheets="@../style/project-list.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.advisora.GUI.Strategie.StrategieInfoDialogController">


    <!-- title bar -->
    <HBox fx:id="dragHandle" alignment="CENTER" spacing="10" styleClass="dialog-header">
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Détail Stratégie" styleClass="dialog-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnClose" text="✕" onAction="#close" styleClass="btn-close"/>
    </HBox>


    <VBox spacing="6">
        <Label prefHeight="25.0" prefWidth="97.0" styleClass="meta-label" text="Stratégie :">
         <font>
            <Font size="16.0" />
         </font></Label>
        <Label fx:id="lblStrategieName" styleClass="big-title" wrapText="true" />
    </VBox>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label prefHeight="25.0" prefWidth="83.0" styleClass="meta-label" text="Objectifs:">
         <font>
            <Font size="16.0" />
         </font></Label>
        <Label fx:id="lblObjectiveCount" styleClass="pill" />
    </HBox>

    <ListView fx:id="listObjectives" prefHeight="320" />

    <padding>
        <Insets bottom="14" left="14" right="14" top="14" />
    </padding>

</VBox>
