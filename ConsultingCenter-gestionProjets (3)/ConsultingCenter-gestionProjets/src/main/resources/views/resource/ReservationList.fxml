<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.advisora.GUI.Ressource.ReservationListController"
      stylesheets="@../style/resource-module.css"
      styleClass="module-root">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Historique Reservations" styleClass="module-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Nouvelle qte"/>
        <TextField fx:id="txtNewQuantity" promptText="ex: 3" prefWidth="100"/>
        <Button text="Modifier" onAction="#onUpdate" styleClass="btn-primary"/>
        <Button text="Supprimer" onAction="#onDelete" styleClass="btn-ghost"/>
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-ghost"/>
    </HBox>

    <HBox fillHeight="true" spacing="16" styleClass="stats">
        <VBox maxWidth="1.7976931348623157E308" prefWidth="320" spacing="8" HBox.hgrow="ALWAYS">
            <styleClass>
                <String fx:value="stat-card"/>
            </styleClass>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="stat-icon-chip stat-icon-orange">
                    <Label text="&#128196;" styleClass="stat-icon-text"/>
                </StackPane>
                <Label text="Nombre reservations" styleClass="stat-label"/>
            </HBox>
            <Label fx:id="lblReservationCount" text="0" styleClass="stat-value"/>
        </VBox>

        <VBox maxWidth="1.7976931348623157E308" prefWidth="320" spacing="8" HBox.hgrow="ALWAYS">
            <styleClass>
                <String fx:value="stat-card"/>
            </styleClass>
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane styleClass="stat-icon-chip stat-icon-yellow">
                    <Label text="&#128230;" styleClass="stat-icon-text"/>
                </StackPane>
                <Label text="Quantite reservee" styleClass="stat-label"/>
            </HBox>
            <Label fx:id="lblReservedQty" text="0" styleClass="stat-value"/>
        </VBox>
    </HBox>

    <ListView fx:id="listReservations" VBox.vgrow="ALWAYS" styleClass="card-list"/>

    <Label fx:id="lblStatus" text="Ready." styleClass="hint"/>
</VBox>
