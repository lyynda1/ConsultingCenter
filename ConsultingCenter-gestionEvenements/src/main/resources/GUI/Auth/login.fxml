<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<BorderPane prefHeight="720" prefWidth="1280"
            stylesheets="@login.css"
            styleClass="app"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.advisora.GUI.Auth.loginController">

    <center>
        <HBox alignment="CENTER" spacing="24">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>

            <VBox alignment="CENTER" spacing="12" styleClass="brand-card">
                <ImageView fitHeight="120" preserveRatio="true">
                    <image>
                        <Image url="@../Admin/icons/ADVISORA.png" />
                    </image>
                </ImageView>
                <Label text="Welcome back" styleClass="brand-title"/>
                <Label text="Connect to continue" styleClass="brand-sub"/>
            </VBox>

            <VBox spacing="14" styleClass="card" prefWidth="420">
                <Label text="Login" styleClass="card-title"/>
                <Label text="Enter your email and password" styleClass="muted"/>

                <VBox spacing="6">
                    <Label text="Email" styleClass="label"/>
                    <TextField fx:id="emailField" promptText="ex: aa@example.com" styleClass="input"/>
                    <Label fx:id="emailError" text="" visible="false" managed="false" styleClass="field-error"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Password" styleClass="label"/>
                    <PasswordField fx:id="passwordField" promptText="••••••••" styleClass="input"/>
                    <Label fx:id="passwordError" text="" visible="false" managed="false" styleClass="field-error"/>
                </VBox>

                <Label fx:id="loginError" text="" visible="false" managed="false" styleClass="field-error"/>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Clear" onAction="#handleClear" styleClass="btn-outline"/>
                    <Button text="Login" onAction="#handleLogin" styleClass="btn-primary"/>
                </HBox>

                <Label fx:id="statusLabel" text="Ready." styleClass="hint"/>
            </VBox>
        </HBox>
    </center>
</BorderPane>
